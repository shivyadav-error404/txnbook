rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User sandboxed ledger hierarchy
    match /users/{userId} {
      // User profile can only be read/updated by the user themselves
      allow read, create, update, delete: if isOwner(userId);
      
      // Friends list managed strictly under user's sandbox
      match /friends/{friendId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(friendId);
      }
      
      // Transactions list managed strictly under user's sandbox
      match /transactions/{transactionId} {
        allow read, create, update, delete: if isOwner(userId) && isValidId(transactionId);
      }
    }
  }
}
